# SupportMind frontend environment
# Copy to .env.local and fill in values.

# Google OAuth Client ID for Google Identity Services.
# Leave blank to use local demo login while developing.
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Local development uses the Vite /api proxy.
# Production should point at the deployed FastAPI backend.
VITE_API_BASE_URL=/api
