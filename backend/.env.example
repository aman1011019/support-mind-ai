# SupportMind backend environment

# Google OAuth 2.0 credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# AI provider key. Leave blank to use deterministic offline fallback responses.
AI_PROVIDER_API_KEY=

# SQLite for development. Use PostgreSQL in production.
DATABASE_URL=sqlite:///./supportmind.db

# App settings.
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

# Optional.
RATE_LIMIT_PER_MINUTE=60
